# Copy to .env and fill in your values

# Database
DB_DATABASE_URL=postgresql+asyncpg://alpha:alpha@localhost:5432/alpha_runtime
DB_ECHO_SQL=false
DB_POOL_SIZE=5

# IBKR
IBKR_HOST=127.0.0.1
IBKR_PORT=7497          # 7497=TWS paper, 7496=TWS live, 4001/4002=Gateway
IBKR_CLIENT_ID=1

# Risk
RISK_PAPER_MODE=true
RISK_MAX_DAILY_LOSS=500.0
RISK_RISK_PER_TRADE=100.0
RISK_MIN_RR=2.0
RISK_MAX_SHARES=500

# API
API_HOST=0.0.0.0
API_PORT=8000
API_SYMBOLS=["QQQ"]
